# Production Environment Configuration
# Use this as a template for production environment variables
# Set these values in your deployment platform (Render.com, etc.)
# NEVER commit actual production values to version control

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME="Identity and Profile Management API"
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION - PRODUCTION SUPABASE
# =============================================================================
# Get from: Supabase Dashboard > Settings > Database
# Use the "Connection pooling" URL for production (uses PgBouncer)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# SUPABASE CONFIGURATION - PRODUCTION
# =============================================================================
# Get from: Supabase Dashboard > Settings > API
# Project URL format: https://[PROJECT-REF].supabase.co
SUPABASE_URL=https://[PROJECT-REF].supabase.co

# Anon Key (public key - safe to expose)
# Get from: Supabase Dashboard > Settings > API > Project API keys > anon public
SUPABASE_ANON_KEY=[YOUR-ANON-KEY-FROM-SUPABASE-DASHBOARD]

# Service Role Key (SECRET - never expose to clients)
# Get from: Supabase Dashboard > Settings > API > Project API keys > service_role secret
SUPABASE_SERVICE_KEY=[YOUR-SERVICE-ROLE-KEY-FROM-SUPABASE-DASHBOARD]

# JWT Secret
# Get from: Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=[YOUR-JWT-SECRET-FROM-SUPABASE-DASHBOARD]

# =============================================================================
# SECURITY CONFIGURATION - PRODUCTION
# =============================================================================
# CRITICAL: Generate a strong secret key
# Generate with: openssl rand -hex 32
# Store securely in deployment platform environment variables
SECRET_KEY=[GENERATE-WITH-OPENSSL-RAND-HEX-32]

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS CONFIGURATION - PRODUCTION
# =============================================================================
# Comma-separated list of allowed origins
# Include your production frontend domains
# Example: https://app.yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS_STR=https://app.yourdomain.com,https://www.yourdomain.com

# =============================================================================
# SMTP CONFIGURATION - PRODUCTION (Mailgun)
# =============================================================================
# Get credentials from Mailgun Dashboard > Sending > Domain settings > SMTP credentials
# US region: smtp.mailgun.org | EU region: smtp.eu.mailgun.org
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Identity Management System
SMTP_USER=postmaster@yourdomain.mailgun.org
SMTP_PASSWORD=[YOUR-MAILGUN-SMTP-PASSWORD]
SMTP_USE_TLS=true

# Frontend and API URLs for email links
FRONTEND_URL=https://app.yourdomain.com
API_BASE_URL=https://api.yourdomain.com

# =============================================================================
# RATE LIMITING - PRODUCTION (recommended)
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# =============================================================================
# REDIS CONFIGURATION - PRODUCTION (recommended for caching)
# =============================================================================
# Consider using Upstash Redis or Redis Cloud for production
REDIS_ENABLED=true
REDIS_URL=redis://:[PASSWORD]@[HOST]:[PORT]/0
REDIS_TTL_SECONDS=300

# =============================================================================
# OBSERVABILITY - PRODUCTION
# =============================================================================
# Sentry for error tracking (recommended)
# Get from: https://sentry.io/
SENTRY_DSN=https://[KEY]@[ORG].ingest.sentry.io/[PROJECT]

# Application Performance Monitoring
APM_ENABLED=true
APM_SERVICE_NAME=identity-api-production

# =============================================================================
# FEATURE FLAGS - PRODUCTION
# =============================================================================
# Enable features gradually in production
FEATURE_OAUTH_ENABLED=true
FEATURE_GUARDIAN_RELATIONSHIPS_ENABLED=true
FEATURE_CONTEXT_PROFILES_ENABLED=true

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# [ ] Generate strong SECRET_KEY with openssl rand -hex 32
# [ ] Set all Supabase credentials from dashboard
# [ ] Update ALLOWED_ORIGINS_STR with production domains
# [ ] Configure Mailgun SMTP credentials
# [ ] Update SMTP_FROM_EMAIL with verified domain
# [ ] Set FRONTEND_URL and API_BASE_URL for email links
# [ ] Enable rate limiting
# [ ] Set up Redis for caching
# [ ] Configure Sentry for error tracking
# [ ] Enable APM monitoring
# [ ] Review and enable feature flags
# [ ] Test all environment variables are set
# [ ] Verify database connection pooling is enabled
# [ ] Ensure DEBUG=false and LOG_LEVEL=INFO

