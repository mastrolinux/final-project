# Identity and Profile Management API - Environment Configuration
# Copy this file to .env and fill in appropriate values for your environment
# NEVER commit .env file to version control

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME="Identity and Profile Management API"
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Connection
# For local Supabase: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# For production: Use connection string from Supabase dashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identity_api
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these values from: https://supabase.com/dashboard/project/_/settings/api
# For local development, run: supabase start
# The output will show your local Supabase URLs and keys

# Supabase Project URL
# Local: http://127.0.0.1:54321
# Production: https://your-project-id.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Supabase Anonymous Key (public key, safe to expose to clients)
# This key has limited permissions defined by Row Level Security
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (SECRET - full admin access)
# NEVER expose this key to clients or commit to version control
# Only use server-side for admin operations
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT Secret for verifying Supabase Auth tokens
# Get from: Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Secret key for signing tokens (generate with: openssl rand -hex 32)
# CRITICAL: Change this in production and keep it secret
SECRET_KEY=change-this-to-a-random-secret-key-in-production-use-openssl-rand-hex-32

# JWT Algorithm
ALGORITHM=HS256

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins for CORS
# Local development: http://localhost:3000,http://localhost:8000
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:8000

# =============================================================================
# RATE LIMITING (optional - for future implementation)
# =============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# =============================================================================
# REDIS CONFIGURATION (optional - for caching, future implementation)
# =============================================================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=300

# =============================================================================
# OBSERVABILITY (optional)
# =============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=

# Application Performance Monitoring
APM_ENABLED=false
APM_SERVICE_NAME=identity-api

# =============================================================================
# FEATURE FLAGS (for gradual rollout of features)
# =============================================================================
FEATURE_OAUTH_ENABLED=false
FEATURE_GUARDIAN_RELATIONSHIPS_ENABLED=false
FEATURE_CONTEXT_PROFILES_ENABLED=false

