# Environment Configuration
#
# For local development: copy env.local.template to .env
#   cp env.local.template .env
#
# For production (Render.com): see env.production.template
#   Secrets are managed via Render dashboard environment groups.
#
# Required variables (app will fail to start without these):
#   DATABASE_URL        - PostgreSQL connection string
#   SECRET_KEY          - Application secret (32+ chars in production)
#   SMTP_FROM_EMAIL     - Sender email address
#   SMTP_FROM_NAME      - Sender display name
#   ALLOWED_ORIGINS_STR - Comma-separated CORS origins

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Security
SECRET_KEY=local-development-secret-key-not-for-production
JWT_SECRET_KEY=local-jwt-secret-key-for-development-only

# Application
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:8000

# Email (Mailpit via local Supabase)
SMTP_HOST=127.0.0.1
SMTP_PORT=54325
SMTP_FROM_EMAIL=noreply@identity-api.local
SMTP_FROM_NAME=Identity Management System
SMTP_USE_TLS=false

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
