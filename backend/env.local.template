# Local Development Environment Configuration
# Copy this file to .env for local development with Supabase
# Run 'supabase start' first, then update keys from its output

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME="Identity and Profile Management API"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# DATABASE CONFIGURATION - LOCAL SUPABASE
# =============================================================================
# Local Supabase PostgreSQL connection
# This is the direct database connection (bypass Supabase API)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# SUPABASE CONFIGURATION - LOCAL
# =============================================================================
# Local Supabase instance
# Run 'supabase start' and copy the values from its output
SUPABASE_URL=http://127.0.0.1:54321

# Get these from 'supabase start' output
# anon key: Look for "anon key:" in the output
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# service_role key: Look for "service_role key:" in the output
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# JWT secret: Look for "JWT secret:" in the output
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# =============================================================================
# SECURITY CONFIGURATION - LOCAL
# =============================================================================
# For local development, use a simple secret (NOT for production)
SECRET_KEY=local-development-secret-key-not-for-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS CONFIGURATION - LOCAL
# =============================================================================
# Allow localhost origins for local development
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# =============================================================================
# JWT AUTHENTICATION CONFIGURATION - LOCAL
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=local-jwt-secret-key-for-development-only-change-in-production

# =============================================================================
# REDIS CONFIGURATION - LOCAL (for Celery)
# =============================================================================
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SMTP CONFIGURATION - LOCAL (Mailpit via Supabase)
# =============================================================================
# Mailpit captures all emails locally - view at http://127.0.0.1:54324
# No authentication required for local development
SMTP_HOST=127.0.0.1
SMTP_PORT=54325
SMTP_FROM_EMAIL=noreply@identity-api.local
SMTP_FROM_NAME=Identity Management System
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# =============================================================================
# OPTIONAL SERVICES - LOCAL
# =============================================================================
RATE_LIMIT_ENABLED=false
APM_ENABLED=false
SENTRY_DSN=

# =============================================================================
# OAUTH 2.0 SOCIAL LOGIN CONFIGURATION
# =============================================================================
# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Create OAuth 2.0 Client ID -> Web application
# Add authorized redirect URI: http://localhost:8000/api/v1/auth/social/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/social/google/callback

# =============================================================================
# ADMIN CONFIGURATION
# =============================================================================
# Comma-separated list of admin user emails (bootstrap admins)
# These users have admin access even if is_admin=false in DB
# Example: admin@example.com,superuser@example.com
ADMIN_USER_EMAILS=sarah.chen@example.com

# =============================================================================
# LOCAL SUPABASE SERVICE URLS (from 'supabase start')
# =============================================================================
# These are for reference and debugging
# Studio URL: http://127.0.0.1:54323
# Inbucket (email testing): http://127.0.0.1:54324
# API URL: http://127.0.0.1:54321
# DB URL: postgresql://postgres:postgres@127.0.0.1:54322/postgres

