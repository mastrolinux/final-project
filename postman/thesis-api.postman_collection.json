    {
      "name": "02 - Create Context Profile",
      "item": [
        {
          "name": "Create Professional Context (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"context_type\": \"professional\",\n  \"context_name\": \"{{context_name}}\",\n  \"display_name_override\": \"Dr. Sarah Chen, MD, PhD\",\n  \"email_override\": \"s.chen@hospital.org\",\n  \"bio\": \"Board-certified psychiatrist specializing in trauma and PTSD\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/profiles/{{sarah_user_id}}/contexts",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "profiles", "{{sarah_user_id}}", "contexts"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate unique context name to prevent 409 conflicts",
                  "const timestamp = Date.now();",
                  "const contextName = `Test-Professional-${timestamp}`;",
                  "",
                  "// Store in collection variable for use in request",
                  "pm.collectionVariables.set(\"context_name\", contextName);",
                  "",
                  "console.log(`Creating context: ${contextName} for user: ${pm.environment.get(\"sarah_user_id\")}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has context data\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    pm.expect(jsonData).to.have.property(\"context_type\");",
                  "    pm.expect(jsonData.context_type).to.eql(\"professional\");",
                  "    ",
                  "    pm.expect(jsonData).to.have.property(\"display_name_override\");",
                  "    pm.expect(jsonData.display_name_override).to.include(\"Dr. Sarah Chen\");",
                  "    ",
                  "    pm.expect(jsonData).to.have.property(\"email_override\");",
                  "    pm.expect(jsonData.email_override).to.eql(\"s.chen@hospital.org\");",
                  "    ",
                  "    pm.expect(jsonData).to.have.property(\"is_active\");",
                  "    pm.expect(jsonData.is_active).to.be.true;",
                  "    ",
                  "    pm.expect(jsonData).to.have.property(\"id\");",
                  "});",
                  "",
                  "pm.test(\"Save context_id for subsequent requests\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"prof_context_id\", jsonData.id);",
                  "    console.log(`Saved professional context ID: ${jsonData.id}`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
