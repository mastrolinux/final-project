    {
      "name": "04 - Get Resolved Profile (CRITICAL)",
      "item": [
        {
          "name": "Resolve Context with Full Overrides",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/profiles/{{sarah_user_id}}/contexts/{{prof_context_id}}/resolved",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "profiles", "{{sarah_user_id}}", "contexts", "{{prof_context_id}}", "resolved"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Overrides are applied\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    pm.expect(jsonData.display_name).to.include(\"Dr. Sarah Chen\");",
                  "    pm.expect(jsonData.email).to.eql(\"s.chen@hospital.org\");",
                  "    pm.expect(jsonData.bio).to.include(\"psychiatrist\");",
                  "});",
                  "",
                  "pm.test(\"Base profile fields preserved\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.account_type).to.eql(\"verified\");",
                  "    pm.expect(jsonData.preferred_language).to.eql(\"en\");",
                  "});",
                  "",
                  "pm.test(\"Context metadata included\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"context_type\");",
                  "    pm.expect(jsonData.context_type).to.eql(\"professional\");",
                  "});",
                  "",
                  "pm.test(\"Identity names included\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"identity_names\");",
                  "    pm.expect(jsonData.identity_names).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
