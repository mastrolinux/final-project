/{context_id}/resolved":{"get":{"tags":["Contexts"],"summary":"Get Resolved Context Profile","description":"Get fully resolved profile with context inheritance applied\n\n**CRITICAL ENDPOINT: Demonstrates the inheritance engine**\n\nThis endpoint implements Goffman's dramaturgical theory by merging:\n1. Base profile fields\n2. Context-specific overrides\n3. Multilingual name resolution\n\nThe resolved profile is what third-party applications receive via OAuth.\n\n**Inheritance Rules:**\n- Start with base profile values\n- Apply context overrides (null overrides inherit from base)\n- Filter deprecated names unless explicitly requested\n- Resolve multilingual names using language preference\n\n**Example:**\n- Base profile: email=personal@example.com, phone=+1-555-1234\n- Professional context: email_override=work@company.com, phone_override=None\n- Resolved: email=work@company.com, phone=+1-555-1234 (inherited)","operationId":"get_resolved_context_profile_api_v1_profiles__user_id__contexts__context_id__resolved_get","parameters":[{"name":"user_id","in":"path","required":true,"schema":{"type":"string","format":"uuid","title":"User Id"}},{"name":"context_id","in":"path","required":true,"schema":{"type":"string","format":"uuid","title":"Context Id"}},{"name":"language","in":"query","required":false,"schema":{"type":"string","description":"Language code for name resolution (ISO 639-1)","default":"en","title":"Language"},"description":"Language code for name resolution (ISO 639-1)"},{"name":"include_deprecated","in":"query","required":false,"schema":{"type":"boolean","description":"Include deprecated names in results","default":false,"title":"Include Deprecated"},"description":"Include deprecated names in results"}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ResolvedProfileResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schem